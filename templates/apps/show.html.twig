{% extends 'base.html.twig' %}

{% set is_pl = lang == 'pl' %}

{# TODO: replace these placeholder URLs with the real store / install links #}
{% set ios_url = 'https://apps.apple.com/us/app/ferrio-unusual-holidays/id6464416113' %}
{% set android_url = 'https://play.google.com/store/apps/details?id=eu.andret.kalendarzswiatnietypowych' %}
{% set discord_url = 'https://discord.com/oauth2/authorize?client_id=1500796951308927026' %}

{% block title %}{{ is_pl ? 'Aplikacje Ferrio – pobierz na iOS, Android i Discord' : 'Ferrio Apps – Download for iOS, Android and Discord' }}{% endblock %}
{% block meta_description %}{{ is_pl ? 'Pobierz aplikację Ferrio na iPhone\'a i Androida lub dodaj bota Discord do swojego serwera.' : 'Get the Ferrio app on iPhone and Android, or add the Ferrio bot to your Discord server.' }}{% endblock %}

{% block meta_extra %}
	{% set page_title = is_pl ? 'Aplikacje Ferrio – pobierz na iOS, Android i Discord' : 'Ferrio Apps – Download for iOS, Android and Discord' %}
	{% set page_desc = is_pl ? 'Pobierz aplikację Ferrio na iPhone\'a i Androida lub dodaj bota Discord do swojego serwera.' : 'Get the Ferrio app on iPhone and Android, or add the Ferrio bot to your Discord server.' %}
	{% set page_url = url('apps') %}

	{% include 'partials/meta_tags.html.twig' with {
		meta_title: page_title,
		meta_description: page_desc,
		meta_url: page_url,
	} %}

	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		"name": "{{ page_title|e('js') }}",
		"description": "{{ page_desc|e('js') }}",
		"url": "{{ page_url|e('js') }}",
		"isPartOf": {
			"@type": "WebSite",
			"name": "Ferrio",
			"url": "{{ url('home')|e('js') }}"
		},
		"breadcrumb": {
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "{{ is_pl ? 'Strona główna' : 'Home' }}",
					"item": "{{ url('home')|e('js') }}"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "{{ page_title|e('js') }}",
					"item": "{{ page_url|e('js') }}"
				}
			]
		}
	}
	</script>
{% endblock %}

{% block body %}
	<main id="main-content" class="mb-16 sm:mb-20 md:mb-24">
		<div class="text-center mb-10">
			<div class="inline-flex p-3 bg-amber-100 dark:bg-amber-900/30 rounded-full mb-4">
				<svg class="w-8 h-8 text-amber-600 dark:text-amber-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5 14.25 3v7.5h6L9.75 21v-7.5h-6Z"/>
				</svg>
			</div>
			<h1 class="text-3xl sm:text-4xl font-bold bg-linear-to-r from-amber-600 via-orange-600 to-rose-600 bg-clip-text text-transparent pb-1 mb-3">
				{{ is_pl ? 'Ferrio na każdej platformie' : 'Ferrio everywhere you are' }}
			</h1>
			<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-xl mx-auto">
				{{ is_pl ? 'Te same dane o świętach – do wyboru: w przeglądarce, na telefonie i na serwerze Discord.' : 'The same holiday data, available in your browser, on your phone, and on your Discord server.' }}
			</p>
		</div>

		<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
			{# iOS #}
			<div class="bg-white/70 dark:bg-gray-800/70 backdrop-blur-sm rounded-2xl shadow-sm border border-amber-100/80 dark:border-gray-700 p-6 flex flex-col">
				<div class="flex items-center gap-3 mb-4">
					<div class="inline-flex p-2.5 rounded-xl bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900">
						<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
							<path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zM256.4 84.5c30.1-35.8 27.4-68.4 26.5-80.5-26.6 1.5-57.4 18.1-74.9 38.6-19.3 22-30.6 49.2-28.2 79.9 28.8 2.2 55.1-12.6 76.6-38z"/>
						</svg>
					</div>
					<div>
						<h2 class="text-base font-bold text-gray-900 dark:text-gray-100">iOS</h2>
						<p class="text-xs text-gray-500 dark:text-gray-400">{{ is_pl ? 'iPhone i iPad' : 'iPhone & iPad' }}</p>
					</div>
				</div>
				<p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-5 grow">
					{{ is_pl ? 'Natywna aplikacja na iPhone\'a i iPada – sprawdzaj święta na dziś, przeglądaj nadchodzące dni i otrzymuj powiadomienia.' : 'Native iPhone and iPad app — check today\'s holidays, browse upcoming days, and get notifications.' }}
				</p>
				{% set badge_locale = is_pl ? 'pl' : 'en' %}
				{% set app_store_label = is_pl ? 'Pobierz w App Store' : 'Download on the App Store' %}
				<a href="{{ ios_url }}" target="_blank" rel="noopener"
				   aria-label="{{ app_store_label }}"
				   class="inline-block self-center hover:opacity-90 transition-opacity duration-200">
					<img
							src="/images/app-store-{{ badge_locale }}-light.svg"
							alt="{{ app_store_label }}"
							width="180"
							height="53"
							class="h-[53px] w-auto block dark:hidden"
							loading="lazy">
					<img
							src="/images/app-store-{{ badge_locale }}-dark.svg"
							alt="{{ app_store_label }}"
							width="180"
							height="53"
							class="h-[53px] w-auto hidden dark:block"
							loading="lazy">
				</a>
			</div>

			{# Android #}
			<div class="bg-white/70 dark:bg-gray-800/70 backdrop-blur-sm rounded-2xl shadow-sm border border-amber-100/80 dark:border-gray-700 p-6 flex flex-col">
				<div class="flex items-center gap-3 mb-4">
					<div class="inline-flex p-2.5 rounded-xl bg-emerald-500 text-white">
						<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill="currentColor" aria-hidden="true">
							<path d="M420.55 301.93a24 24 0 1 1 24-24 24 24 0 0 1-24 24m-265.1 0a24 24 0 1 1 24-24 24 24 0 0 1-24 24m273.7-144.48 47.94-83a10 10 0 1 0-17.27-10l-48.54 84.07a301.25 301.25 0 0 0-246.56 0L116.18 64.45a10 10 0 1 0-17.27 10l47.94 83C64.53 202.22 8.24 285.55 0 384h576c-8.24-98.45-64.54-181.78-146.85-226.55"/>
						</svg>
					</div>
					<div>
						<h2 class="text-base font-bold text-gray-900 dark:text-gray-100">Android</h2>
						<p class="text-xs text-gray-500 dark:text-gray-400">{{ is_pl ? 'Telefon i tablet' : 'Phone & tablet' }}</p>
					</div>
				</div>
				<p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-5 grow">
					{{ is_pl ? 'Natywna aplikacja na Androida – wszystkie święta pod ręką, ulubione daty i widget na ekran główny.' : 'Native Android app — every holiday at hand, favourite dates, and a home‑screen widget.' }}
				</p>
				<a href="{{ android_url }}" target="_blank" rel="noopener"
				   aria-label="{{ is_pl ? 'Pobierz w Google Play' : 'Get it on Google Play' }}"
				   class="inline-block self-center hover:opacity-90 transition-opacity duration-200">
					<img
							src="/images/google-play-{{ is_pl ? 'pl' : 'en' }}.svg"
							alt="{{ is_pl ? 'Pobierz w Google Play' : 'Get it on Google Play' }}"
							width="180"
							height="53"
							class="h-[53px] w-auto"
							loading="lazy">
				</a>
			</div>

			{# Discord #}
			<div class="bg-white/70 dark:bg-gray-800/70 backdrop-blur-sm rounded-2xl shadow-sm border border-amber-100/80 dark:border-gray-700 p-6 flex flex-col sm:col-span-2 lg:col-span-1">
				<div class="flex items-center gap-3 mb-4">
					<div class="inline-flex p-2.5 rounded-xl bg-indigo-500 text-white">
						<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" fill="currentColor" aria-hidden="true">
							<path d="M524.5 69.8a1.5 1.5 0 0 0-.8-.7A485.1 485.1 0 0 0 404.1 32a1.8 1.8 0 0 0-1.9.9 337.5 337.5 0 0 0-14.9 30.6 447.8 447.8 0 0 0-134.4 0 309.5 309.5 0 0 0-15.1-30.6 1.9 1.9 0 0 0-1.9-.9A483.7 483.7 0 0 0 116.1 69.1a1.7 1.7 0 0 0-.8.7C39.1 183.7 18.2 294.7 28.4 404.4a2 2 0 0 0 .8 1.4A487.7 487.7 0 0 0 176 479.9a1.9 1.9 0 0 0 2.1-.7 348.2 348.2 0 0 0 30-48.8 1.9 1.9 0 0 0-1-2.6 321.2 321.2 0 0 1-45.9-21.9 1.9 1.9 0 0 1-.2-3.1c3.1-2.3 6.2-4.7 9.1-7.1a1.8 1.8 0 0 1 1.9-.3c96.2 43.9 200.4 43.9 295.5 0a1.8 1.8 0 0 1 1.9.2c2.9 2.4 6 4.9 9.1 7.2a1.9 1.9 0 0 1-.2 3.1 301.4 301.4 0 0 1-45.9 21.8 1.9 1.9 0 0 0-1 2.6 391.1 391.1 0 0 0 30 48.8 1.9 1.9 0 0 0 2.1.7A486 486 0 0 0 610.7 405.7a1.9 1.9 0 0 0 .8-1.4c12.2-126.7-20.6-236.8-87.1-334.5zM222.5 337.6c-29 0-52.8-26.6-52.8-59.2S193 219.1 222.5 219.1c29.7 0 53.3 26.8 52.8 59.2 0 32.6-23.4 59.2-52.8 59.2zm195.4 0c-29 0-52.8-26.6-52.8-59.2s23.3-59.2 52.8-59.2c29.7 0 53.3 26.8 52.8 59.2 0 32.6-23.1 59.2-52.8 59.2z"/>
						</svg>
					</div>
					<div>
						<h2 class="text-base font-bold text-gray-900 dark:text-gray-100">Discord</h2>
						<p class="text-xs text-gray-500 dark:text-gray-400">{{ is_pl ? 'Bot na Twój serwer' : 'Bot for your server' }}</p>
					</div>
				</div>
				<p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-5 grow">
					{{ is_pl ? 'Dodaj bota Ferrio do swojego serwera Discord i sprawdzaj święta komendami slash.' : 'Add the Ferrio bot to your Discord server and look up holidays with slash commands.' }}
				</p>
				<a href="{{ discord_url }}" target="_blank" rel="noopener"
				   aria-label="{{ is_pl ? 'Dodaj na serwer Discord' : 'Add to Discord server' }}"
				   class="self-center inline-flex items-center justify-center gap-2 bg-[#5865F2] hover:bg-[#4752C4] text-white font-semibold rounded-xl transition-colors duration-200 shadow-sm h-[53px] w-[180px]">
					<svg class="w-6 h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" fill="currentColor" aria-hidden="true">
						<path d="M524.5 69.8a1.5 1.5 0 0 0-.8-.7A485.1 485.1 0 0 0 404.1 32a1.8 1.8 0 0 0-1.9.9 337.5 337.5 0 0 0-14.9 30.6 447.8 447.8 0 0 0-134.4 0 309.5 309.5 0 0 0-15.1-30.6 1.9 1.9 0 0 0-1.9-.9A483.7 483.7 0 0 0 116.1 69.1a1.7 1.7 0 0 0-.8.7C39.1 183.7 18.2 294.7 28.4 404.4a2 2 0 0 0 .8 1.4A487.7 487.7 0 0 0 176 479.9a1.9 1.9 0 0 0 2.1-.7 348.2 348.2 0 0 0 30-48.8 1.9 1.9 0 0 0-1-2.6 321.2 321.2 0 0 1-45.9-21.9 1.9 1.9 0 0 1-.2-3.1c3.1-2.3 6.2-4.7 9.1-7.1a1.8 1.8 0 0 1 1.9-.3c96.2 43.9 200.4 43.9 295.5 0a1.8 1.8 0 0 1 1.9.2c2.9 2.4 6 4.9 9.1 7.2a1.9 1.9 0 0 1-.2 3.1 301.4 301.4 0 0 1-45.9 21.8 1.9 1.9 0 0 0-1 2.6 391.1 391.1 0 0 0 30 48.8 1.9 1.9 0 0 0 2.1.7A486 486 0 0 0 610.7 405.7a1.9 1.9 0 0 0 .8-1.4c12.2-126.7-20.6-236.8-87.1-334.5zM222.5 337.6c-29 0-52.8-26.6-52.8-59.2S193 219.1 222.5 219.1c29.7 0 53.3 26.8 52.8 59.2 0 32.6-23.4 59.2-52.8 59.2zm195.4 0c-29 0-52.8-26.6-52.8-59.2s23.3-59.2 52.8-59.2c29.7 0 53.3 26.8 52.8 59.2 0 32.6-23.1 59.2-52.8 59.2z"/>
					</svg>
					<span class="text-sm leading-none">{{ is_pl ? 'Dodaj bota' : 'Add to server' }}</span>
				</a>
			</div>
		</div>

		<p class="mt-8 text-center text-xs text-gray-500 dark:text-gray-400">
			{{ is_pl ? 'Korzystając z aplikacji akceptujesz' : 'By using the apps you accept the' }}
			<a href="{{ path('terms') }}" class="text-amber-600 dark:text-amber-400 underline hover:text-amber-700 dark:hover:text-amber-300">{{ is_pl ? 'Regulamin' : 'Terms of Service' }}</a>
			{{ is_pl ? 'oraz' : 'and' }}
			<a href="{{ path('privacy') }}" class="text-amber-600 dark:text-amber-400 underline hover:text-amber-700 dark:hover:text-amber-300">{{ is_pl ? 'Politykę prywatności' : 'Privacy Policy' }}</a>.
		</p>
	</main>
{% endblock %}
