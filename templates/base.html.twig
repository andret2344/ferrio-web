<!DOCTYPE html>
<html lang="{{ lang|default('en') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Ferrio{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Discover the world's most unusual holidays{% endblock %}">
        <meta name="color-scheme" content="light dark">
        <link rel="icon" href="{{ asset('favicon.ico') }}">

        {% block meta_extra %}{% endblock %}

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        <script>
            (function() {
                var saved = localStorage.getItem('theme');
                var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                if (saved === 'dark' || (!saved && prefersDark)) {
                    document.documentElement.classList.add('dark');
                }
            })();
        </script>
    </head>
    <body>
        <div class="min-h-screen bg-linear-to-br from-amber-50 via-orange-50 to-rose-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900 transition-colors duration-300">
            {% include 'partials/navbar.html.twig' %}

            <div class="container mx-auto px-4 py-6 sm:py-8 max-w-4xl pt-20 sm:pt-24">
                {% block body %}{% endblock %}

                {% include 'partials/footer.html.twig' %}
            </div>
        </div>

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </body>
</html>
