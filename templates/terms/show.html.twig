		<div class="text-center mb-8">
			<div class="inline-flex p-3 bg-amber-100 dark:bg-amber-900/30 rounded-full mb-4">
				<svg
						class="w-8 h-8 text-amber-600 dark:text-amber-400"
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="1.5"
						stroke="currentColor">
					<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
				</svg>
			</div>
			<h1 class="text-3xl sm:text-4xl font-bold bg-linear-to-r from-amber-600 via-orange-600 to-rose-600 bg-clip-text text-transparent pb-1 mb-3">
				{{ is_pl ? 'Regulamin aplikacji Ferrio' : 'Terms of Service – Ferrio App' }}
