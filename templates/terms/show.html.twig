					{{ _self.list_item(is_pl ? 'przyjmuje do wiadomości, że Usługodawca nie ma obowiązku zaakceptowania, opublikowania ani zachowania zgłoszonej treści.' : 'acknowledge that the Provider is under no obligation to accept, publish, or retain the submitted content.') }}
				</ul>
			</section>
			<hr class="border-gray-100 dark:border-gray-700">

			{# Section 6 #}
			<section>
				{{ _self.section_title(is_pl ? '6. Dozwolone i zabronione korzystanie' : '6. Acceptable Use') }}
				{{ _self.para(is_pl ? 'Korzystając z Usług, użytkownik zobowiązuje się nie:' : 'When using the Services, you agree not to:') }}
