					{{ _self.list_item(is_pl ? 'wysyłać zgłoszeń zawierających treści nielegalne, obraźliwe, dyskryminujące, wulgarne, nawołujące do przemocy lub w inny sposób nieodpowiednie,' : 'submit reports that are illegal, abusive, discriminatory, obscene, threatening, or otherwise inappropriate,') }}
