			<section>
				{{ _self.section_title(is_pl ? '16. Kontakt' : '16. Contact') }}
				{{ _self.para((is_pl ? 'Pytania dotyczące Regulaminu można kierować na adres ' : 'Questions about these Terms can be sent to ') ~ _self.email_link(contact_email) ~ '.') }}
