<div class="bg-white dark:bg-gray-800 rounded-2xl sm:rounded-3xl shadow-2xl px-10 py-8 md:px-14 md:py-12 mb-6 sm:mb-8 border border-gray-100 dark:border-gray-700 hover:shadow-3xl transition-shadow duration-300">
    <h2 class="text-xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white wrap-break-word mb-3">
        {{ holiday.name }}
    </h2>

    <div class="flex items-center gap-2 mb-4 sm:mb-6">
        {# Country #}
        {% if holiday.country %}
            <span class="text-xl sm:hidden" aria-hidden="true">{{ holiday.country.flag }}</span>
            <span class="text-sm text-gray-600 dark:text-gray-400">{{ holiday.country.name }}</span>
        {% else %}
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400 sm:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><title>International</title><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>
            <span class="text-sm text-gray-600 dark:text-gray-400">{{ lang == 'pl' ? 'Międzynarodowe' : 'International' }}</span>
        {% endif %}

        {# Unusual badge #}
        {% if holiday.usual %}
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-50 dark:bg-gray-400/40 text-gray-700 dark:text-gray-300">
                {{ lang == 'pl' ? 'Typowe' : 'Usual' }}
            </span>
        {% else %}
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400">
                {{ lang == 'pl' ? 'Nietypowe' : 'Unusual' }}
            </span>
        {% endif %}
    </div>

    {# Description #}
    {% if holiday.description is not empty %}
        <div class="flex flex-col gap-3">
            {% for paragraph in holiday.description|split("\n") %}
                {% if paragraph|trim is not empty %}
                    <p class="text-base sm:text-lg text-gray-700 dark:text-gray-300 leading-relaxed">{{ paragraph }}</p>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}

    {# Learn more #}
    {% if holiday.url is not empty %}
        <a href="{{ holiday.url }}" target="_blank" rel="noopener noreferrer"
           class="inline-block mt-4 text-sm font-medium text-amber-600 dark:text-amber-400 hover:text-amber-700 dark:hover:text-amber-300 underline underline-offset-2">
            {{ lang == 'pl' ? 'Dowiedz się więcej' : 'Learn more' }} &rarr;
        </a>
    {% endif %}
</div>
