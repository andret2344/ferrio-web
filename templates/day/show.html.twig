{% extends 'base.html.twig' %}

{% block title %}{{ dayResult ? dayResult.formattedDate : '' }} - Ferrio{% endblock %}
{% block meta_description %}{{ lang == 'pl' ? 'Odkryj święta na ' ~ (dayResult ? dayResult.formattedDate : '') : 'Discover holidays on ' ~ (dayResult ? dayResult.formattedDate : '') }}{% endblock %}

{% block meta_extra %}
    <meta property="og:title" content="{{ dayResult ? dayResult.formattedDate : '' }} - Ferrio">
    <meta property="og:description" content="{{ lang == 'pl' ? 'Odkryj święta na ' ~ (dayResult ? dayResult.formattedDate : '') : 'Discover holidays on ' ~ (dayResult ? dayResult.formattedDate : '') }}">
    <meta property="og:type" content="website">
    <link rel="canonical" href="{{ url('day', {month: month, day: day}) }}">
{% endblock %}

{% block body %}
    <main class="mb-16 sm:mb-20 md:mb-24">
        {% include 'partials/header.html.twig' %}

        {% if not hasError %}
            {# Date navigation #}
            <div class="mb-4 sm:mb-6 flex flex-col items-center gap-1.5">
                <div class="flex items-center w-64">
                    <a href="{{ path('day', {month: prevDay.month, day: prevDay.day}) }}"
                       class="shrink-0 p-1 rounded-full text-amber-700 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 transition-colors cursor-pointer"
                       aria-label="Previous day">
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                    </a>

                    <div class="flex-1 flex justify-center">
                        <span class="px-3 py-1.5 sm:px-4 sm:py-2 bg-linear-to-r from-amber-100 to-orange-100 dark:from-amber-900/30 dark:to-orange-900/30 text-amber-800 dark:text-amber-300 rounded-full text-xs sm:text-sm font-semibold">
                            {{ dayResult.formattedDate }}
                        </span>
                    </div>

                    <a href="{{ path('day', {month: nextDay.month, day: nextDay.day}) }}"
                       class="shrink-0 p-1 rounded-full text-amber-700 dark:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 transition-colors cursor-pointer"
                       aria-label="Next day">
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    </a>
                </div>

                <a href="{{ path('day', {month: randomDay.month, day: randomDay.day}) }}"
                   class="p-1 rounded-full text-gray-400 dark:text-gray-500 hover:text-amber-700 dark:hover:text-amber-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 transition-colors cursor-pointer"
                   aria-label="Random day">
                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
                </a>
            </div>
        {% endif %}

        {# Content #}
        {% if hasError %}
            {% include 'partials/error.html.twig' %}
        {% elseif dayResult.holidays|length == 0 %}
            <div class="text-center py-12 text-gray-600 dark:text-gray-400">
                {{ lang == 'pl' ? 'Nie znaleziono świąt na ten dzień.' : 'No holidays found for this date.' }}
            </div>
        {% else %}
            {# Holiday carousel #}
            <div class="relative px-2 sm:px-4 md:px-0" id="carousel" data-count="{{ dayResult.holidays|length }}">
                {% for holiday in dayResult.holidays %}
                    <div class="carousel-slide {{ loop.first ? '' : 'hidden' }}" data-index="{{ loop.index0 }}">
                        {% include 'partials/holiday_card.html.twig' with {holiday: holiday} %}
                    </div>
                {% endfor %}

                {% if dayResult.holidays|length > 1 %}
                    {# Prev button #}
                    <button id="carousel-prev"
                            class="absolute left-0 sm:left-2 md:left-0 top-8 sm:top-10 md:top-12 -translate-x-2 sm:-translate-x-3 md:-translate-x-4 lg:-translate-x-6 w-10 h-10 sm:w-11 sm:h-11 md:w-12 md:h-12 flex items-center justify-center bg-white dark:bg-gray-800 rounded-full shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-110 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 cursor-pointer"
                            aria-label="Previous holiday">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                    </button>

                    {# Next button #}
                    <button id="carousel-next"
                            class="absolute right-0 sm:right-2 md:right-0 top-8 sm:top-10 md:top-12 translate-x-2 sm:translate-x-3 md:translate-x-4 lg:translate-x-6 w-10 h-10 sm:w-11 sm:h-11 md:w-12 md:h-12 flex items-center justify-center bg-white dark:bg-gray-800 rounded-full shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-110 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 cursor-pointer"
                            aria-label="Next holiday">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    </button>

                    {# Dots #}
                    <div class="flex justify-center gap-1.5 sm:gap-2 mt-4 sm:mt-6" id="carousel-dots">
                        {% for holiday in dayResult.holidays %}
                            <button class="carousel-dot w-2 h-2 rounded-full transition-all duration-200 cursor-pointer {{ loop.first ? 'bg-gradient-to-r from-amber-600 to-orange-600 w-6 sm:w-8' : 'bg-gray-300 dark:bg-gray-600 hover:bg-gray-400 dark:hover:bg-gray-500' }}"
                                    data-index="{{ loop.index0 }}"
                                    aria-label="Go to holiday {{ loop.index }}"></button>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endif %}
    </main>
{% endblock %}
